{
  "manifest_version": 3,
  "name": "Broditor",
  "version": "1.0.0",
  "description": "Captures browser activity and syncs audit events to the Browser Activity Audit & Compliance Platform.",
  "icons": {
    "16": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "webNavigation",
    "idle",
    "downloads",
    "alarms",
    "windows"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "storage": {
    "managed_schema": "managed_schema.json"
  }
}
